{
  "build": {
    "compile": {
      "module": "compile",
      "args": {
        "cmd": "dotnet build"
      }
    },
    "codesign": {
      "module": "codesign",
      "args": {
        "path_env": "codesign_path",
        "cmd": "codesign my_build.dll"
      }
    },
    "compress": {
      "module": "compress",
      "args": {
        "format": "zstd",
        "input": "binaries"
      }
    },
    "zip": {
      "module": "zip",
      "args": {
        "files": "my_folder"
      }
    }
  },
  "upload": {
    "artifactory": {
      "module": "artifactory",
      "args": {
        "token_env": "artifactory_token_env",
        "jfrog_path_env": "jfrog_path_env",
        "cmd": "jfrogv2.exe upload"
      }
    }
  }
}